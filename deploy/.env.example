# Copy to `.env` and fill in real values (never commit `.env`).
#   cp deploy/.env.example deploy/.env
#
# Rust Core (rust-core / SFU) — often loaded by the same file if your unit runs both.
# -----------------------------------------------------------------------------

SFU_PUBLIC_IP=YOUR_PUBLIC_IP_HERE
SFU_UDP_PORT=50000
SFU_HTTP_HOST=127.0.0.1
SFU_HTTP_PORT=8080
SFU_BIND_IP=0.0.0.0
SFU_ARCHIVE_DIR=/opt/livecam/archive
HLS_DIR=/opt/livecam/hls

# Go Proxy (go-features/api)
# -----------------------------------------------------------------------------

GO_LISTEN_PORT=8443
CLIENT_DIR=/opt/livecam/client
RUST_CORE_URL=http://127.0.0.1:8080

STUN_URL=stun:stun.l.google.com:19302
# TURN_URL=turn:turn.example.com:3478
# TURN_USERNAME=
# TURN_CREDENTIAL=

# Session + broadcast page (generate a long random SESSION_SECRET for production)
SESSION_SECRET=CHANGE_ME_MINIMUM_16_CHARS_RANDOM
BROADCAST_PASSWORD=

# WHIP publish whitelist: comma-separated 32-char alphanumeric keys (empty = open mode)
ALLOWED_STREAM_KEYS=

# Donations (SQLite) + optional Stripe webhook verification
DONATION_DB_PATH=/opt/livecam/data/donations.db
# STRIPE_WEBHOOK_SECRET=

# Offline banner image uploads (defaults under client dir if unset)
# OFFLINE_BANNER_UPLOAD_DIR=/opt/livecam/data/offline_banners
